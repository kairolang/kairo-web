---
import { Code } from 'astro:components';

let kairoLang: any = 'rust';
try {
  const res = await fetch(
    'https://raw.githubusercontent.com/kairolang/kairo-lsp/lsp-v1/public/syntaxes/kairo.tmLanguage.json'
  );
  if (res.ok) kairoLang = await res.json();
} catch {}

const examples = [
  {
    id: 'hello',
    label: 'Hello World',
    filename: 'hello.kairo',
    code: `fn main() {
    // Variables are immutable by default
    let name = "Kairo";
    let mut count: i32 = 0;

    // f-strings for string interpolation
    for i in 0..3 {
        print(f"[{i}] Hello from {name}!");
        count += 1;
    }

    print(f"Ran {count} times.");
}`,
  },
  {
    id: 'memory',
    label: 'Memory Safety',
    filename: 'memory.kairo',
    code: `// Kairo's ownership model prevents use-after-free
struct Buffer {
    data: *mut u8,
    len:  usize,
}

impl Buffer {
    fn new(size: usize) -> Buffer {
        return Buffer {
            data: alloc(size),
            len: size,
        };
    }

    fn ~Buffer() {  // destructor
        free(self.data);
    }
}

fn main() {
    let buf = Buffer::new(1024);
    // buf freed automatically here
}`,
  },
  {
    id: 'interop',
    label: 'C++ Interop',
    filename: 'ffi.kairo',
    code: `// Direct C/C++ interop — zero overhead
extern "C" {
    fn printf(fmt: *const char, ...) -> i32;
    fn malloc(size: usize) -> *mut void;
    fn free(ptr: *mut void);
}

// Link against C++ libraries
@link("stdc++")
extern "C++" {
    class std::vector<T>;
}

fn main() {
    // Call C directly — no wrapping
    unsafe {
        printf(c"Hello from C: %d\\n", 42);
    }
}`,
  },
];
---

<section style="padding:7rem 0;background:var(--bg-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);position:relative;overflow:hidden;">
  <!-- Subtle diagonal pattern -->
  <div style="position:absolute;inset:0;background-image:repeating-linear-gradient(45deg,rgba(189,9,32,0.015) 0,rgba(189,9,32,0.015) 1px,transparent 0,transparent 50%);background-size:30px 30px;pointer-events:none;"></div>
  <div class="container" style="position:relative;z-index:1;">
    <div style="margin-bottom:3rem;" data-reveal>
      <div class="section-label">Code</div>
      <h2 style="
        font-family:'Space Grotesk',sans-serif;
        font-size:clamp(1.75rem,4vw,2.75rem);
        font-weight:700;
        letter-spacing:-0.03em;
        line-height:1.1;
        color:var(--text);
        max-width:500px;
      ">
        See it in action - <br>
        <span style="color:var(--text-2);font-weight:400;">Clean syntax.<br>No magic.</span>
      </h2>
    </div>

    <div style="max-width:760px;" data-reveal data-reveal-delay="100">
      <!-- Tab buttons -->
      <div style="display:flex;border-bottom:1px solid var(--border);margin-bottom:0;" id="code-tabs">
        {examples.map((ex, i) => (
          <button
            class={`tab-btn ${i === 0 ? 'active' : ''}`}
            data-tab={ex.id}
          >{ex.label}</button>
        ))}
      </div>

      <!-- Tab panels -->
      {examples.map((ex, i) => (
        <div
          class="code-panel"
          data-panel={ex.id}
          style={i !== 0 ? 'display:none;' : ''}
        >
          <!-- Header — matches hero code block style -->
          <div class="showcase-header">
            <div class="showcase-dots">
              <span style="background:#ff5f57;"></span>
              <span style="background:#febc2e;"></span>
              <span style="background:#28c840;"></span>
            </div>
            <span class="showcase-filename">{ex.filename}</span>
            <span class="showcase-badge">kairo</span>
          </div>
          <div class="showcase-body">
            <Code
              code={ex.code}
              lang={kairoLang}
              themes={{ dark: 'github-dark', light: 'github-light' }}
              defaultColor={false}
            />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .code-panel {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--red);
    border-top: none;
    border-radius: 0 0 2px 2px;
    overflow: hidden;
    box-shadow: 0 0 30px rgba(0,0,0,0.2), 0 0 16px var(--red-glow2);
    transition: opacity 0.15s;
  }
  .code-panel.glitch-in {
    animation: glitchText 0.12s steps(1) 1;
  }

  .showcase-header {
    background: var(--bg-3);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 1px solid var(--border);
  }
  .showcase-dots { display: flex; gap: 6px; align-items: center; }
  .showcase-dots span { width: 12px; height: 12px; border-radius: 50%; display: block; }
  .showcase-filename {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.75rem;
    color: var(--text-3);
    letter-spacing: 0.05em;
    flex: 1;
  }
  .showcase-badge {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--red);
    background: rgba(189,9,32,0.1);
    border: 1px solid rgba(189,9,32,0.2);
    padding: 2px 8px;
    border-radius: 2px;
  }

  .showcase-body :global(pre.astro-code) {
    margin: 0 !important;
    border: none !important;
    border-radius: 0 !important;
    padding: 1.5rem !important;
    font-size: 0.85rem !important;
    line-height: 1.75 !important;
    font-family: 'JetBrains Mono', monospace !important;
    background: transparent !important;
  }
</style>

<script>
  function initCodeTabs() {
    const tabsContainer = document.getElementById('code-tabs');
    if (!tabsContainer) return;

    const buttons = tabsContainer.querySelectorAll('.tab-btn');
    const panels = document.querySelectorAll('.code-panel');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = (btn as HTMLElement).dataset.tab;

        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        panels.forEach(panel => {
          const p = panel as HTMLElement;
          const isTarget = p.dataset.panel === target;
          p.style.display = isTarget ? 'block' : 'none';
          if (isTarget) {
            p.classList.remove('glitch-in');
            void p.offsetWidth;
            p.classList.add('glitch-in');
            p.addEventListener('animationend', () => p.classList.remove('glitch-in'), { once: true });
          }
        });
      });
    });
  }

  initCodeTabs();
  document.addEventListener('astro:page-load', initCodeTabs);
</script>
