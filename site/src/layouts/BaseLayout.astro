---
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  /** Controls structured data output; defaults to 'page' */
  type?: 'home' | 'docs' | 'blog' | 'page';
  /** 'article' for blog posts */
  ogType?: 'website' | 'article';
  pubDate?: Date;
  modDate?: Date;
  author?: string;
  tags?: string[];
  breadcrumbs?: Array<{ name: string; url: string }>;
  noindex?: boolean;
}

const {
  title,
  description = 'Kairo is a modern systems programming language. Control everything. Compromise nothing.',
  ogImage = '/kairo-logo.svg',
  canonical,
  type = 'page',
  ogType = 'website',
  pubDate,
  modDate,
  author,
  tags = [],
  breadcrumbs = [],
  noindex = false,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <Seo
      title={title}
      description={description}
      canonicalURL={canonicalURL}
      ogImage={ogImage}
      ogType={ogType}
      type={type}
      pubDate={pubDate}
      modDate={modDate}
      author={author}
      tags={tags}
      breadcrumbs={breadcrumbs}
      noindex={noindex}
    />

    <link rel="icon" href="/kairo-file-icon.svg" type="image/svg+xml" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- Theme detection — runs before render to avoid flash -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          if (stored === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          } else {
            document.documentElement.removeAttribute('data-theme');
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <!-- Custom cursor orb -->
    <div id="cursor-orb" aria-hidden="true"></div>
    <div id="cursor-orb-outer" aria-hidden="true"></div>
    <Header />
    <!-- Noise/grain overlay -->
    <div aria-hidden="true" style="
      position:fixed;
      inset:0;
      pointer-events:none;
      z-index:9999;
      opacity:0.025;
      background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/></filter><rect width=%22200%22 height=%22200%22 filter=%22url(%23n)%22 opacity=%221%22/></svg>');
      background-repeat:repeat;
      background-size:200px 200px;
    "></div>
    <slot />
    <Footer />
    <script is:inline>
      // Custom cursor orb tracking
      (function() {
        var orb = document.getElementById('cursor-orb');
        var outer = document.getElementById('cursor-orb-outer');
        if (!orb || !outer) return;
        var tx = window.innerWidth / 2, ty = window.innerHeight / 2;
        var cx = tx, cy = ty, ox = tx, oy = ty;
        var raf;
        document.addEventListener('mousemove', function(e) {
          tx = e.clientX; ty = e.clientY;
        }, { passive: true });
        document.addEventListener('mousedown', function() {
          outer.style.width = '20px';
          outer.style.height = '20px';
          outer.style.borderColor = 'rgba(189,9,32,0.8)';
        });
        document.addEventListener('mouseup', function() {
          outer.style.width = '32px';
          outer.style.height = '32px';
          outer.style.borderColor = 'rgba(189,9,32,0.4)';
        });
        // Expand on links/buttons
        document.querySelectorAll('a,button').forEach(function(el) {
          el.addEventListener('mouseenter', function() {
            outer.style.width = '48px';
            outer.style.height = '48px';
            outer.style.borderColor = 'rgba(189,9,32,0.7)';
          });
          el.addEventListener('mouseleave', function() {
            outer.style.width = '32px';
            outer.style.height = '32px';
            outer.style.borderColor = 'rgba(189,9,32,0.4)';
          });
        });
        function loop() {
          cx += (tx - cx) * 0.9;
          cy += (ty - cy) * 0.9;
          ox += (tx - ox) * 0.12;
          oy += (ty - oy) * 0.12;
          orb.style.left = cx + 'px';
          orb.style.top  = cy + 'px';
          outer.style.left = ox + 'px';
          outer.style.top  = oy + 'px';
          raf = requestAnimationFrame(loop);
        }
        loop();
      })();
    </script>
    <script is:inline>
      // Scroll reveal observer
      (function() {
        const observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) {
              const delay = e.target.dataset.revealDelay || 0;
              setTimeout(function() {
                e.target.classList.add('revealed');
              }, +delay);
              observer.unobserve(e.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

        function scanReveal() {
          document.querySelectorAll('[data-reveal]:not(.revealed)').forEach(function(el) {
            observer.observe(el);
          });
        }

        scanReveal();
        document.addEventListener('astro:page-load', scanReveal);
      })();
    </script>
  </body>
</html>
