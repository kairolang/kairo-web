---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  function idToSlug(id: string): string {
    return id.replace(/\.mdx?$/, '').replace(/\/index$/, '');
  }

  function docHref(id: string): string {
    const clean = idToSlug(id);
    if (!clean || clean === 'index') return '/docs';
    return `/docs/${clean}`;
  }

  const docs = await getCollection('docs');

  const sorted = [...docs].sort((a, b) => {
    const orderA = a.data.order ?? 99;
    const orderB = b.data.order ?? 99;
    return orderA - orderB;
  });

  return docs.map(doc => {
    const slug = idToSlug(doc.id);
    const idx = sorted.findIndex(d => d.id === doc.id);
    const prevDoc = idx > 0 ? sorted[idx - 1] : null;
    const nextDoc = idx < sorted.length - 1 ? sorted[idx + 1] : null;

    return {
      params: { slug: slug === 'index' ? undefined : slug },
      props: {
        doc,
        prev: prevDoc ? { href: docHref(prevDoc.id), title: prevDoc.data.title } : null,
        next: nextDoc ? { href: docHref(nextDoc.id), title: nextDoc.data.title } : null,
      },
    };
  });
}

const { doc, prev, next } = Astro.props;
const { Content, headings } = await render(doc);
---
<DocsLayout
  title={doc.data.title}
  description={doc.data.description}
  prev={prev}
  next={next}
  headings={headings}
>
  <Content />
</DocsLayout>
