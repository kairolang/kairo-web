---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import { buildDocTree, flattenPages, docHref } from '../../lib/docs-tree';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  const tree = buildDocTree(docs);
  const ordered = flattenPages(tree);

  return docs.map(doc => {
    const slug = doc.id.replace(/\.mdx?$/, '').replace(/\/index$/, '');
    const idx = ordered.findIndex(p => p.id === doc.id);
    const prevPage = idx > 0 ? ordered[idx - 1] : null;
    const nextPage = idx < ordered.length - 1 ? ordered[idx + 1] : null;

    return {
      params: { slug: slug === 'index' ? undefined : slug },
      props: {
        doc,
        prev: prevPage ? { href: prevPage.href, title: prevPage.title } : null,
        next: nextPage ? { href: nextPage.href, title: nextPage.title } : null,
      },
    };
  });
}

const { doc, prev, next } = Astro.props;
const { Content, headings } = await render(doc);
---
<DocsLayout
  title={doc.data.title}
  description={doc.data.description}
  prev={prev}
  next={next}
  headings={headings}
>
  <Content />
</DocsLayout>
