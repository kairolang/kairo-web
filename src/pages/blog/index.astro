---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout
  title="Blog - Kairo"
  description="Thoughts, updates, and design proposals from the Kairo language team."
>
  <!-- Header -->
  <section style="
    padding:6rem 0 4rem;
    background:var(--bg);
    border-bottom:1px solid var(--border);
    position:relative;
    overflow:hidden;
  ">
    <div class="hero-grid" style="opacity:0.4;"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="section-label">Blog</div>
      <h1 style="
        font-family:'Space Grotesk',sans-serif;
        font-size:clamp(2rem,5vw,3.5rem);
        font-weight:700;
        letter-spacing:-0.03em;
        line-height:1.1;
        color:var(--text);
        margin-bottom:1rem;
      ">Thoughts &amp; Updates</h1>
      <p style="
        font-family:'Inter',sans-serif;
        font-size:1.05rem;
        color:var(--text-2);
        max-width:500px;
        line-height:1.65;
      ">
        Design decisions, language proposals, and updates from the Kairo team
        and community contributors.
      </p>
    </div>
  </section>

  <!-- Post list -->
  <section style="padding:5rem 0;">
    <div class="container" style="max-width:900px;">
      {posts.length === 0 ? (
        <div style="
          text-align:center;
          padding:5rem 2rem;
          color:var(--text-3);
          font-family:'Space Grotesk',sans-serif;
        ">
          <p style="font-size:1.25rem;margin-bottom:0.5rem;">No posts yet.</p>
          <p style="font-size:0.875rem;">Check back soon.</p>
        </div>
      ) : (
        <div style="display:flex;flex-direction:column;gap:1rem;">
          {posts.map(post => {
            const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });
            return (
              <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} class="blog-card">
                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.75rem;">
                  <span style="
                    font-family:'Space Grotesk',sans-serif;
                    font-size:0.75rem;
                    color:var(--text-3);
                    letter-spacing:0.05em;
                  ">{formattedDate}</span>
                  <span style="
                    font-family:'Space Grotesk',sans-serif;
                    font-size:0.75rem;
                    color:var(--text-3);
                  ">By {post.data.author}</span>
                </div>
                <h2 style="
                  font-family:'Space Grotesk',sans-serif;
                  font-size:1.25rem;
                  font-weight:700;
                  letter-spacing:-0.02em;
                  color:var(--text);
                  margin-bottom:0.6rem;
                  line-height:1.3;
                  transition:color 0.2s;
                ">{post.data.title}</h2>
                <p style="
                  font-family:'Inter',sans-serif;
                  font-size:0.9rem;
                  color:var(--text-2);
                  line-height:1.65;
                  margin-bottom:1rem;
                ">{post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div style="display:flex;flex-wrap:wrap;gap:6px;">
                    {post.data.tags.map(tag => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
