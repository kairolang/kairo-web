---
// Fetch live data from GitHub at build time
let stars = 320;
let contributors = 6;
let forks = 12;

try {
  const [repoRes, contribRes] = await Promise.all([
    fetch('https://api.github.com/repos/kairolang/kairo-lang', {
      headers: { 'Accept': 'application/vnd.github.v3+json', 'User-Agent': 'kairo-web' },
    }),
    fetch('https://api.github.com/repos/kairolang/kairo-lang/contributors?per_page=100', {
      headers: { 'Accept': 'application/vnd.github.v3+json', 'User-Agent': 'kairo-web' },
    }),
  ]);

  if (repoRes.ok) {
    const repo = await repoRes.json();
    stars = repo.stargazers_count ?? stars;
    forks = repo.forks_count ?? forks;
  }
  if (contribRes.ok) {
    const contribs = await contribRes.json();
    contributors = Array.isArray(contribs) ? contribs.length : contributors;
  }
} catch (e) {
  console.warn('[kairo-web] GitHub API fetch failed, using fallback stats');
}

const stats = [
  { value: stars,        suffix: '+', label: 'GitHub Stars',       desc: 'and growing' },
  { value: 55,           suffix: '+', label: 'Weekly Downloads',   desc: 'from releases' },
  { value: contributors, suffix: '',  label: 'Contributors',       desc: 'open source' },
  { value: forks,        suffix: '',  label: 'Forks',              desc: 'on GitHub' },
];
---

<section style="padding:7rem 0;background:var(--bg);position:relative;overflow:hidden;">
  <div style="
    position:absolute;top:50%;left:50%;
    transform:translate(-50%,-50%);
    width:600px;height:300px;
    background:radial-gradient(ellipse at center, var(--red-glow2) 0%, transparent 70%);
    pointer-events:none;
    animation:hexPulse 5s ease-in-out infinite;
  "></div>

  <!-- Scan sweep line (activated on count-up) -->
  <div class="stats-scan-line" id="stats-scan" aria-hidden="true"></div>

  <div class="container" style="position:relative;z-index:1;">
    <div style="margin-bottom:3.5rem;" data-reveal>
      <div class="section-label">By the Numbers</div>
      <h2 style="font-family:'Space Grotesk',sans-serif;font-size:clamp(1.75rem,4vw,2.75rem);font-weight:700;letter-spacing:-0.03em;color:var(--text);">
        Early — and accelerating.
      </h2>
    </div>

    <div class="stats-grid" id="stats-grid" data-reveal>
      {stats.map((stat, i) => (
        <div class="stat-cell" style={`--i:${i}`}>
          <div class="stat-bar"></div>
          <!-- Scan sweep on reveal -->
          <div class="stat-scan-v"></div>
          <div style="position:relative;display:inline-block;">
            <div class="stat-number" data-target={stat.value} data-suffix={stat.suffix}>
              0{stat.suffix}
            </div>
            <!-- Pulse ring -->
            <span class="pulse-ring stat-pulse"></span>
          </div>
          <div class="stat-label">{stat.label}</div>
          <div class="stat-desc">{stat.desc}</div>
          <!-- HUD corner -->
          <span class="stat-index">{String(i + 1).padStart(2, '0')}</span>
        </div>
      ))}
    </div>

    <p class="stats-footer" data-reveal>
      Alpha stage · Compiler written in C++ · Self-hosting in progress
    </p>
  </div>
</section>

<style>
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .stat-cell {
    background: var(--bg-2);
    padding: 2.5rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }
  .stat-cell:hover { background: var(--bg-3); }

  /* Hover top bar */
  .stat-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, var(--red), transparent);
    opacity: 0;
    transition: opacity 0.4s;
  }
  .stat-cell:hover .stat-bar { opacity: 1; }

  /* Vertical scan sweep */
  .stat-scan-v {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 40%;
    background: linear-gradient(to bottom, rgba(189,9,32,0.06), transparent);
    transform: translateY(-100%);
    pointer-events: none;
    transition: none;
  }
  .stat-cell.scanning .stat-scan-v {
    animation: scanSweep 1s ease-out forwards;
  }

  .stat-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--text);
    letter-spacing: 0.01em;
    margin-bottom: 0.25rem;
    margin-top: 0.5rem;
  }
  .stat-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: var(--text-3);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .stat-index {
    position: absolute;
    top: 0.75rem; right: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.55rem;
    color: var(--text-3);
    letter-spacing: 0.1em;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .stat-cell:hover .stat-index { opacity: 1; color: var(--red); }

  /* Scan line across whole section */
  .stats-scan-line {
    position: absolute;
    left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(189,9,32,0.6), transparent);
    top: 0;
    pointer-events: none;
    opacity: 0;
    z-index: 2;
  }
  .stats-scan-line.run {
    animation: scanSweep 1.5s ease-out forwards;
  }

  .stats-footer {
    text-align: center;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.75rem;
    color: var(--text-3);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-top: 1.5rem;
  }

  @media (max-width: 768px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .stats-grid { grid-template-columns: 1fr; } }
</style>

<script>
  function initStats() {
    const grid = document.getElementById('stats-grid');
    const scanLine = document.getElementById('stats-scan');
    if (!grid) return;
    const numbers = grid.querySelectorAll('.stat-number');
    const cells = grid.querySelectorAll('.stat-cell');
    let animated = false;

    function easeOut(t: number) { return 1 - Math.pow(1 - t, 3); }

    function animateCount(el: Element) {
      const target = parseInt((el as HTMLElement).dataset.target || '0');
      const suffix = (el as HTMLElement).dataset.suffix || '';
      const duration = 1400;
      const start = performance.now();
      function step(now: number) {
        const progress = Math.min((now - start) / duration, 1);
        el.textContent = Math.floor(easeOut(progress) * target) + suffix;
        if (progress < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    function triggerPulseRing(cell: Element) {
      const ring = cell.querySelector('.stat-pulse') as HTMLElement | null;
      if (!ring) return;
      ring.classList.remove('active');
      void ring.offsetWidth; // reflow
      ring.classList.add('active');
      ring.addEventListener('animationend', () => ring.classList.remove('active'), { once: true });
    }

    function triggerScan(cell: Element) {
      cell.classList.remove('scanning');
      void (cell as HTMLElement).offsetWidth;
      cell.classList.add('scanning');
    }

    new IntersectionObserver(entries => {
      if (entries[0].isIntersecting && !animated) {
        animated = true;
        // Horizontal scan sweep first
        if (scanLine) {
          scanLine.classList.add('run');
          scanLine.addEventListener('animationend', () => scanLine.classList.remove('run'), { once: true });
        }
        cells.forEach((cell, i) => {
          setTimeout(() => triggerScan(cell), i * 100 + 200);
        });
        numbers.forEach((el, i) => {
          setTimeout(() => {
            animateCount(el);
            const cell = el.closest('.stat-cell');
            if (cell) triggerPulseRing(cell);
          }, i * 150 + 400);
        });
      }
    }, { threshold: 0.3 }).observe(grid);
  }
  initStats();
  document.addEventListener('astro:page-load', initStats);
</script>
