---
---
<section class="cta-section">
  <!-- Red glow background -->
  <div class="cta-glow"></div>

  <!-- Grid overlay -->
  <div class="hero-grid" style="opacity:0.4;"></div>

  <!-- Animated corner brackets (HUD style) -->
  <div class="cta-bracket cta-bracket-tl"></div>
  <div class="cta-bracket cta-bracket-tr"></div>
  <div class="cta-bracket cta-bracket-bl"></div>
  <div class="cta-bracket cta-bracket-br"></div>

  <!-- Orbiting decorative dots -->
  <div class="cta-orbit-ring" aria-hidden="true">
    <span class="cta-orbit-dot"></span>
  </div>

  <!-- Data streams (vertical) -->
  <div class="cta-data-streams" aria-hidden="true">
    <span class="cta-ds cta-ds-1"></span>
    <span class="cta-ds cta-ds-2"></span>
    <span class="cta-ds cta-ds-3"></span>
    <span class="cta-ds cta-ds-4"></span>
  </div>

  <div class="container" style="position:relative;z-index:1;text-align:center;">
    <!-- HUD readout -->
    <div class="cta-hud-row" data-reveal>
      <span class="cta-hud-item">SYS::READY</span>
      <span class="cta-hud-sep">--</span>
      <span class="cta-hud-item"><span class="cta-hud-dot"></span>KAIRO v0.1.0-alpha</span>
      <span class="cta-hud-sep">--</span>
      <span class="cta-hud-item">KSF OPEN SOURCE</span>
    </div>

    <!-- Label -->
    <div style="display:flex;justify-content:center;margin-bottom:1.5rem;" data-reveal>
      <div class="section-label">Get Started</div>
    </div>

    <h2 class="cta-title" data-reveal>
      Ready to build<br>
      <span class="cta-future hero-red neon-text">the future?</span>
    </h2>

    <p class="cta-sub" data-reveal>
      Join the small but growing community of systems programmers
      who refuse to compromise on performance or ergonomics.
    </p>

    <div class="cta-actions" data-reveal>
      <a href="/docs" class="btn-primary border-beam" style="font-size:1rem;padding:14px 36px;">
        Start with Docs
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a
        href="https://github.com/kairolang/kairo-lang"
        class="btn-outline"
        target="_blank"
        rel="noopener noreferrer"
        style="font-size:1rem;padding:14px 36px;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        Join on GitHub
      </a>
    </div>

    <!-- Bottom tagline -->
    <p class="cta-footer-note" data-reveal>
      Apache 2.0 License · Kairo Software Foundation · Open Source
    </p>
  </div>
</section>

<style>
  .cta-section {
    padding: 8rem 0;
    background: var(--bg);
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 800px; height: 400px;
    background: radial-gradient(ellipse at center, rgba(189,9,32,0.12) 0%, transparent 65%);
    pointer-events: none;
    animation: hexPulse 4s ease-in-out infinite;
  }

  /* Corner brackets */
  .cta-bracket {
    position: absolute;
    width: 40px; height: 40px;
    border-color: rgba(189,9,32,0.3);
    border-style: solid;
    pointer-events: none;
    z-index: 2;
    transition: all 0.6s ease;
    animation: hexPulse 3s ease-in-out infinite;
  }
  .cta-bracket-tl { top: 2rem; left: 2rem; border-width: 2px 0 0 2px; }
  .cta-bracket-tr { top: 2rem; right: 2rem; border-width: 2px 2px 0 0; animation-delay: 0.5s; }
  .cta-bracket-bl { bottom: 2rem; left: 2rem; border-width: 0 0 2px 2px; animation-delay: 1s; }
  .cta-bracket-br { bottom: 2rem; right: 2rem; border-width: 0 2px 2px 0; animation-delay: 1.5s; }

  @media (max-width: 768px) {
    .cta-bracket { display: none; }
  }

  /* Orbiting ring */
  .cta-orbit-ring {
    position: absolute;
    top: 50%; left: 50%;
    width: 1px; height: 1px;
    pointer-events: none;
    z-index: 0;
  }
  .cta-orbit-dot {
    display: block;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--red);
    box-shadow: 0 0 8px var(--red-glow);
    animation: orbitCW 8s linear infinite;
    transform-origin: center center;
  }

  /* Data streams */
  .cta-data-streams { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
  .cta-ds {
    position: absolute;
    top: 0; width: 1px; height: 80px;
    background: linear-gradient(to bottom, transparent, rgba(189,9,32,0.5), transparent);
    animation: dataStream linear infinite;
  }
  .cta-ds-1 { left: 5%;  animation-duration: 8s;  animation-delay: 0s; }
  .cta-ds-2 { left: 30%; animation-duration: 12s; animation-delay: 2s; }
  .cta-ds-3 { left: 70%; animation-duration: 9s;  animation-delay: 5s; }
  .cta-ds-4 { left: 92%; animation-duration: 11s; animation-delay: 1s; }

  /* HUD readout row */
  .cta-hud-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: var(--text-3);
    text-transform: uppercase;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }
  .cta-hud-item { display: flex; align-items: center; gap: 6px; }
  .cta-hud-sep  { color: var(--border-hi); }
  .cta-hud-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--red);
    box-shadow: 0 0 6px var(--red-glow);
    animation: glowPulse 2s ease-in-out infinite;
  }

  /* Title */
  .cta-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--text);
    margin-bottom: 1.5rem;
  }
  .cta-future {
    color: var(--red);
    text-shadow: 0 0 40px var(--red-glow), 0 0 80px var(--red-glow2);
    display: inline-block;
    cursor: default;
  }

  .cta-sub {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    color: var(--text-2);
    max-width: 500px;
    margin: 0 auto 3rem;
    line-height: 1.7;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cta-footer-note {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.75rem;
    color: var(--text-3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 3rem;
  }
</style>
