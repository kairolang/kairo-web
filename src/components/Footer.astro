---
---
<footer style="
  background:var(--bg-2);
  border-top:1px solid var(--border);
  padding:4rem 0 2rem;
  margin-top:auto;
">
  <div class="container">
    <!-- 3-column grid -->
    <div style="
      display:grid;
      grid-template-columns:2fr 1fr 1fr;
      gap:3rem;
      padding-bottom:3rem;
      border-bottom:1px solid var(--border);
    " class="footer-grid">
      <!-- Column 1: Logo + tagline -->
      <div>
        <a href="/" style="display:inline-flex;align-items:center;gap:10px;text-decoration:none;margin-bottom:1rem;">
          <img src="/kairo-logo.svg" alt="Kairo" width="24" height="24" />
          <span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1rem;color:var(--text);">kairo</span>
        </a>
        <p style="
          font-family:'Inter',sans-serif;
          font-size:0.875rem;
          color:var(--text-3);
          line-height:1.6;
          max-width:280px;
          margin-bottom:1rem;
        ">
          Control everything. Compromise nothing.<br>
          A modern systems programming language.
        </p>
        <p style="
          font-size:0.75rem;
          color:var(--text-3);
          font-family:'Space Grotesk',sans-serif;
          letter-spacing:0.02em;
        ">
          Built by the
          <a href="/ksf" style="color:var(--red);text-decoration:none;border-bottom:1px solid transparent;transition:border-color 0.2s;" onmouseenter="this.style.borderColor='var(--red)'" onmouseleave="this.style.borderColor='transparent'">
            Kairo Software Foundation
          </a>
        </p>
      </div>

      <!-- Column 2: Language links -->
      <div>
        <p style="
          font-family:'Space Grotesk',sans-serif;
          font-size:0.7rem;
          font-weight:700;
          letter-spacing:0.12em;
          text-transform:uppercase;
          color:var(--text-3);
          margin-bottom:1rem;
        ">Language</p>
        <div style="display:flex;flex-direction:column;gap:0.6rem;">
          {[
            { href: '/docs', label: 'Documentation' },
            { href: '/docs/install', label: 'Installation' },
            { href: '/blog', label: 'Blog' },
            { href: 'https://github.com/kairolang/kairo-lang/releases', label: 'Changelog ↗', external: true },
          ].map(link => (
            <a
              href={link.href}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener noreferrer' : undefined}
              style="
                font-family:'Inter',sans-serif;
                font-size:0.875rem;
                color:var(--text-2);
                text-decoration:none;
                transition:color 0.2s;
              "
              onmouseenter="this.style.color='var(--text)'"
              onmouseleave="this.style.color='var(--text-2)'"
            >{link.label}</a>
          ))}
        </div>
      </div>

      <!-- Column 3: Community links -->
      <div>
        <p style="
          font-family:'Space Grotesk',sans-serif;
          font-size:0.7rem;
          font-weight:700;
          letter-spacing:0.12em;
          text-transform:uppercase;
          color:var(--text-3);
          margin-bottom:1rem;
        ">Community</p>
        <div style="display:flex;flex-direction:column;gap:0.6rem;">
          {[
            { href: 'https://github.com/kairolang/kairo-lang', label: 'GitHub ↗', external: true },
            { href: '/ksf', label: 'KSF' },
            { href: 'https://discord.gg/kairo', label: 'Discord ↗', external: true },
            { href: 'https://x.com/kairolang', label: 'Twitter/X ↗', external: true },
          ].map(link => (
            <a
              href={link.href}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener noreferrer' : undefined}
              style="
                font-family:'Inter',sans-serif;
                font-size:0.875rem;
                color:var(--text-2);
                text-decoration:none;
                transition:color 0.2s;
              "
              onmouseenter="this.style.color='var(--text)'"
              onmouseleave="this.style.color='var(--text-2)'"
            >{link.label}</a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding-top:1.5rem;
      flex-wrap:wrap;
      gap:1rem;
    ">
      <p style="
        font-family:'Space Grotesk',sans-serif;
        font-size:0.75rem;
        color:var(--text-3);
        letter-spacing:0.02em;
      ">
        &copy; {new Date().getFullYear()} Kairo Software Foundation. Open source under the
        <a
          href="https://github.com/kairolang/kairo-lang/blob/main/LICENSE"
          target="_blank"
          rel="noopener noreferrer"
          style="color:var(--text-3);text-decoration:none;border-bottom:1px solid var(--border);"
          onmouseenter="this.style.color='var(--red)';this.style.borderColor='var(--red)'"
          onmouseleave="this.style.color='var(--text-3)';this.style.borderColor='var(--border)'"
        >Apache 2.0 License (with Runtime Exception)</a>.
      </p>
      <div style="display:flex;align-items:center;gap:6px;">
        <span style="width:6px;height:6px;border-radius:50%;background:var(--red);box-shadow:0 0 8px var(--red-glow);display:inline-block;"></span>
        <span style="font-family:'Space Grotesk',sans-serif;font-size:0.7rem;color:var(--text-3);letter-spacing:0.08em;text-transform:uppercase;">v0.1.0-alpha</span>
      </div>
    </div>
  </div>
</footer>

<style>
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
  }
</style>
